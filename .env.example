# x-signals — copy this to .env and fill in your values
# cp .env.example .env

# Required: Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Required: Twitter/X session cookies (log into x.com, open DevTools → Application → Cookies)
TWITTER_AUTH_TOKEN=
TWITTER_CT0=

# Optional: LinkedIn saved posts sync
# Log into linkedin.com → DevTools → Application → Cookies → www.linkedin.com → copy li_at value
# Expires when you log out; re-copy if sync starts failing
LINKEDIN_LI_AT=

# Optional: Telegram notifications
# Create a bot at https://t.me/BotFather, then message your bot to get chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
